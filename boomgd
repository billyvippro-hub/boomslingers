extends RigidBody2D

export(float) var explosion_radius = 120.0
export(float) var explosion_force = 900.0
export(float) var fuse = 2.2

func _ready():
    yield(get_tree().create_timer(fuse), "timeout")
    if is_instance_valid(self):
        explode()

func _integrate_forces(state):
    pass

func _on_body_entered(body):
    explode()

func explode():
    var space_state = get_world_2d().direct_space_state
    var bodies = space_state.get_bodies_in_area(Rect2(position - Vector2(explosion_radius, explosion_radius), Vector2(explosion_radius*2, explosion_radius*2)))
    for b in bodies:
        if b is RigidBody2D:
            var dir = (b.global_position - global_position).normalized()
            var dist = max(1.0, b.global_position.distance_to(global_position))
            var f = (1.0 - clamp(dist / explosion_radius, 0, 1)) * explosion_force
            b.apply_impulse(Vector2(), dir * f)
    queue_free()
